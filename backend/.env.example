# ─────────────────────────────────────────────────────────────────────────────
# Health Ledger — Backend Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Gmail SMTP settings
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-character code
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password

# Display name shown in the From field of every email
SENDER_NAME=Health Ledger RCM Team

# Port the Express server listens on (must match vite proxy target)
PORT=3001
